{
  "scopeName": "source.tourmaline",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.tourmaline",
          "match": "#.*$"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tourmaline",
          "match": "\"([^\\\"]|\\.)*\""
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tourmaline",
          "match": "\\b(print|let|func|end|return|if|else|elif|while|for|in)\\b"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.tourmaline",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.tourmaline",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\s*(?=\\()"
        }
      ]
    }
  },
  "fileTypes": ["toma"],
  "name": "Tourmaline"
}