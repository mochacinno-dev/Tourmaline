{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "scopeName": "source.tourmaline",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.tourmaline",
          "match": "#.*$"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tourmaline",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.tourmaline",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tourmaline",
          "match": "\\b(if|elif|else|while|for|in|end)\\b"
        },
        {
          "name": "keyword.other.tourmaline",
          "match": "\\b(let|function|return|import|module)\\b"
        },
        {
          "name": "keyword.other.print.tourmaline",
          "match": "\\b(print)\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.tourmaline",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.tourmaline",
          "match": "\\b(None|null)\\b"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.tourmaline",
          "match": "\\b[0-9]+\\b"
        },
        {
          "name": "constant.numeric.float.tourmaline",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.tourmaline",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.tourmaline",
          "match": "(\\+|-|\\*|/)"
        },
        {
          "name": "keyword.operator.assignment.tourmaline",
          "match": "="
        },
        {
          "name": "keyword.operator.range.tourmaline",
          "match": "\\.\\."
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.tourmaline",
          "match": "\\b(int|str|bool|list)\\b"
        }
      ]
    },

    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.tourmaline",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },

    "variables": {
      "patterns": [
        {
          "name": "variable.other.tourmaline",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  },
  "fileTypes": ["trm"],
  "name": "Tourmaline"
}