{
  "Print Statement": {
    "prefix": "print",
    "body": "print ${1:value}",
    "description": "Print a value"
  },

  "Let Declaration": {
    "prefix": "let",
    "body": "let ${1:name} = ${2:value}",
    "description": "Declare a variable"
  },

  "Let with Type": {
    "prefix": "lett",
    "body": "let ${1:name}: ${2:type} = ${3:value}",
    "description": "Declare a typed variable"
  },

  "If Statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition}",
      "\t${2:# body}",
      "end"
    ],
    "description": "If statement"
  },

  "If-Else Statement": {
    "prefix": "ife",
    "body": [
      "if ${1:condition}",
      "\t${2:# then}",
      "else",
      "\t${3:# else}",
      "end"
    ],
    "description": "If-else statement"
  },

  "If-Elif-Else Statement": {
    "prefix": "ifel",
    "body": [
      "if ${1:condition}",
      "\t${2:# then}",
      "elif ${3:condition}",
      "\t${4:# elif}",
      "else",
      "\t${5:# else}",
      "end"
    ],
    "description": "If-elif-else statement"
  },

  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition}",
      "\t${2:# body}",
      "end"
    ],
    "description": "While loop"
  },

  "For Range Loop": {
    "prefix": "for",
    "body": [
      "for ${1:i} in ${2:start}..${3:end}",
      "\t${4:# body}",
      "end"
    ],
    "description": "For loop with range"
  },

  "Function Declaration": {
    "prefix": "func",
    "body": [
      "func ${1:name}(${2:params})",
      "\t${3:# body}",
      "\treturn ${4:value}",
      "end"
    ],
    "description": "Function declaration"
  },

  "Function with Typed Parameters": {
    "prefix": "funct",
    "body": [
      "func ${1:name}(${2:param}: ${3:type})",
      "\t${4:# body}",
      "\treturn ${5:value}",
      "end"
    ],
    "description": "Function with typed parameters"
  },

  "Return Statement": {
    "prefix": "ret",
    "body": "return ${1:value}",
    "description": "Return statement"
  },

  "List Literal": {
    "prefix": "list",
    "body": "[${1:elements}]",
    "description": "Create a list"
  },

  "List Access": {
    "prefix": "idx",
    "body": "${1:list}[${2:index}]",
    "description": "Access list element by index"
  },

  "Range Expression": {
    "prefix": "range",
    "body": "${1:start}..${2:end}",
    "description": "Range expression"
  },

  "Import Statement": {
    "prefix": "import",
    "body": "import ${1:module_name}",
    "description": "Import a module"
  },

  "Module Declaration": {
    "prefix": "module",
    "body": [
      "module ${1:name}",
      "\t${2:# module body}",
      "end"
    ],
    "description": "Module declaration"
  },

  "Comment": {
    "prefix": "#",
    "body": "# ${1:comment}",
    "description": "Line comment"
  },

  "Main Block": {
    "prefix": "main",
    "body": [
      "# Main program",
      "${1:# code here}"
    ],
    "description": "Main program block"
  },

  "Comparison Equal": {
    "prefix": "eq",
    "body": "${1:a} == ${2:b}",
    "description": "Equality comparison"
  },

  "Comparison Not Equal": {
    "prefix": "neq",
    "body": "${1:a} != ${2:b}",
    "description": "Not equal comparison"
  },

  "Greater Than": {
    "prefix": "gt",
    "body": "${1:a} > ${2:b}",
    "description": "Greater than comparison"
  },

  "Less Than": {
    "prefix": "lt",
    "body": "${1:a} < ${2:b}",
    "description": "Less than comparison"
  },

  "Boolean True": {
    "prefix": "true",
    "body": "true",
    "description": "Boolean true literal"
  },

  "Boolean False": {
    "prefix": "false",
    "body": "false",
    "description": "Boolean false literal"
  }
}