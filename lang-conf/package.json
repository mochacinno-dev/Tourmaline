{
  "name": "tourmaline-language",
  "displayName": "Tourmaline Language Support",
  "description": "Syntax highlighting, snippets, and language support for Tourmaline (.toma)",
  "version": "0.3.0",
  "publisher": "Mochacinno",
  "engines": {
    "vscode": "^1.50.0"
  },
  "categories": ["Programming Languages", "Snippets"],
  "contributes": {
    "languages": [
      {
        "id": "tourmaline",
        "aliases": ["Tourmaline", "toma"],
        "extensions": [".toma"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tourmaline",
        "scopeName": "source.tourmaline",
        "path": "./syntaxes/tourmaline.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "tourmaline",
        "path": "./snippets/tourmaline.json"
      }
    ]
  }
}